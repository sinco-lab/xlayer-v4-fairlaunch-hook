# PulsePool frontend configuration.
# Copy this file to frontend/.env.local and fill in deployed addresses after broadcast.

VITE_PULSEPOOL_CHAIN_ID=1952
VITE_PULSEPOOL_NETWORK_NAME="X Layer testnet"
VITE_PULSEPOOL_RPC_URL=https://xlayertestrpc.okx.com/terigon
VITE_PULSEPOOL_EXPLORER_URL=https://www.okx.com/web3/explorer/xlayer-test
VITE_PULSEPOOL_ENABLE_WRITES=false

# Required for live reads.
VITE_METRICS_LENS_ADDRESS=
VITE_FAIRFLOW_HOOK_ADDRESS=
VITE_POOL_ID=

# Optional context shown in the UI.
VITE_LAUNCH_FACTORY_ADDRESS=
VITE_SWAP_ROUTER_ADDRESS=
VITE_STATE_VIEW_ADDRESS=
VITE_V4_QUOTER_ADDRESS=
VITE_FLOW_PASS_NFT_ADDRESS=
VITE_LAUNCH_TOKEN_ADDRESS=
VITE_QUOTE_TOKEN_ADDRESS=
VITE_DEMO_SWAP_TX_HASH=
VITE_BROWSER_SWAP_TX_HASH=
VITE_EVENT_BLOCK_WINDOW=250000

# Required before enabling live write flows.
VITE_POOL_MANAGER_ADDRESS=
VITE_POSITION_MANAGER_ADDRESS=
VITE_LAUNCH_TOKEN_SYMBOL=
VITE_QUOTE_TOKEN_SYMBOL=
VITE_TOKEN_DECIMALS=18
VITE_POOL_FEE=8388608
VITE_POOL_TICK_SPACING=60
VITE_SWAP_DEADLINE_SECONDS=3600
