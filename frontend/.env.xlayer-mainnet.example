# X Layer mainnet frontend template.
# Copy to frontend/.env.local only after PulsePool mainnet addresses are deployed.
# Browser writes stay disabled until the mainnet write path is separately proven.

VITE_PULSEPOOL_CHAIN_ID=196
VITE_PULSEPOOL_NETWORK_NAME="X Layer mainnet"
VITE_PULSEPOOL_RPC_URL=https://rpc.xlayer.tech
VITE_PULSEPOOL_EXPLORER_URL=https://www.okx.com/web3/explorer/xlayer
VITE_PULSEPOOL_ENABLE_WRITES=false

# PulsePool mainnet deployment outputs. Fill after broadcast.
VITE_METRICS_LENS_ADDRESS=
VITE_FAIRFLOW_HOOK_ADDRESS=
VITE_POOL_ID=
VITE_LAUNCH_FACTORY_ADDRESS=
VITE_FLOW_PASS_NFT_ADDRESS=

# Frontend read context. Fill after the first mainnet demo transaction.
VITE_DEMO_SWAP_TX_HASH=
VITE_BROWSER_SWAP_TX_HASH=
VITE_EVENT_BLOCK_WINDOW=250000

# Token and pool context. Fill after deployment and pool creation.
VITE_POOL_MANAGER_ADDRESS=0x360E68faccca8cA495c1B759Fd9EEe466db9FB32
VITE_STATE_VIEW_ADDRESS=0x76fD297e2D437cd7f76D50F01AfE6160f86E9990
VITE_V4_QUOTER_ADDRESS=0x8928074ca1b241d8ec02815881c1af11e8bc5219
VITE_PERMIT2_ADDRESS=0x000000000022D473030F116dDEE9F6B43aC78BA3
VITE_SWAP_ROUTER_ADDRESS=0xdA00AE15D3A71466517129255255dB7C0c0956d3
VITE_SWAP_ROUTER_MODE=universal
VITE_LAUNCH_TOKEN_ADDRESS=
VITE_QUOTE_TOKEN_ADDRESS=
VITE_LAUNCH_TOKEN_SYMBOL=
VITE_QUOTE_TOKEN_SYMBOL=
VITE_TOKEN_DECIMALS=18
VITE_POOL_FEE=8388608
VITE_POOL_TICK_SPACING=60
VITE_SWAP_DEADLINE_SECONDS=3600
